# ── Railway PostgreSQL ──────────────────────────────────────────────────────
# Copy from: Railway Dashboard → your project → Postgres plugin → Connect tab
# Format: postgresql://postgres:PASSWORD@HOST.railway.app:PORT/railway
DATABASE_URL=postgresql://postgres:password@monorail.proxy.rlwy.net:PORT/railway

# ── Backend Express service (Railway) ───────────────────────────────────────
# Local: http://localhost:4000
# Docker Compose (internal service-to-service): http://backend:4000
# Railway deployed: https://your-backend-service.railway.app
NEXT_PUBLIC_API_URL=http://localhost:4000

# ── Admin password for /admin/level2 ────────────────────────────────────────
ADMIN_SECRET=changeme-to-something-long-and-random

# ── CORS allow-list for the backend ─────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
